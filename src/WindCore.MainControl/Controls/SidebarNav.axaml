<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WindCore.MainControl.Controls.SidebarNav">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,4">
        <StackPanel x:Name="sidebarRoot" Spacing="0" Background="Transparent">
        </StackPanel>
    </ScrollViewer>
</UserControl>
