<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WindCore.MainControl.ViewModels"
        xmlns:views="using:WindCore.MainControl.Views"
        xmlns:controls="using:WindCore.MainControl.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1040"
        x:Class="WindCore.MainControl.Views.MainWindow"
        x:Name="mainWindow"
        Width="480" Height="420"
        WindowStartupLocation="CenterScreen"
        Title="南京609风洞测控系统 - 主控软件">

    <Panel x:DataType="vm:MainWindowViewModel">
        <!-- 登录页面 (登录成功后自动隐藏) -->
        <views:LoginView x:Name="loginView" DataContext="{Binding LoginViewModel}"/>

        <!-- 登录遮罩 (登录成功后覆盖登录页) -->
        <Panel IsVisible="{Binding IsLoggedIn}" Background="Transparent"/>

        <!-- 主页面 (登录后显示) -->
        <DockPanel IsVisible="{Binding IsLoggedIn}">

            <!-- 顶部标题栏 -->
            <Border DockPanel.Dock="Top" Height="48" Background="#0052D9" Padding="16,0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="609项目" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF"/>
                        <TextBlock Text="风洞测控系统" FontSize="15" FontWeight="Bold" Foreground="#A8D4FF"/>
                        <Border Background="#0034B5" CornerRadius="3" Padding="6,2">
                            <TextBlock Text="独立运行程序" FontSize="11" Foreground="#A8D4FF"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,4,0"/>
                        <TextBlock Text="系统运行中" FontSize="12" Foreground="#FFFFFF"/>
                        <TextBlock Text="|" FontSize="12" Foreground="#6CB4EE" Margin="8,0"/>
                        <TextBlock Text="已运行 72h 15m 33s" FontSize="12" Foreground="#A8D4FF"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Background="#0034B5" CornerRadius="3" Padding="6,2">
                            <TextBlock Text="{Binding CurrentUser}" FontSize="11" Foreground="#A8D4FF"/>
                        </Border>
                        <TextBlock Text="2026-05-20 11:30:00" FontSize="13" Foreground="#A8D4FF" FontFamily="Consolas"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 工具栏 -->
            <Border DockPanel.Dock="Top" Height="36" Background="#F5F7FA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <Button Classes="primary" Content="启动试验" Height="24" Padding="12,0"/>
                    <Button Classes="default" Content="暂停" Height="24" Padding="12,0" IsEnabled="False"/>
                    <Button Classes="danger" Content="停止试验" Height="24" Padding="12,0" IsEnabled="False"/>
                    <Rectangle Width="1" Fill="#D8D8D8" Height="18" Margin="4,0"/>
                    <Button Classes="default" Content="保存数据" Height="24" Padding="12,0"/>
                    <Button Classes="default" Content="导出报表" Height="24" Padding="12,0"/>
                    <Rectangle Width="1" Fill="#D8D8D8" Height="18" Margin="4,0"/>
                    <Button Classes="default" Content="数据回放" Height="24" Padding="12,0"/>
                    <Rectangle Width="1" Fill="#D8D8D8" Height="18" Margin="4,0"/>
                    <Button Classes="default" Content="刷新" Height="24" Padding="12,0"/>
                    <TextBlock Text="当前试验: 空载基准试验 #20260520-001 | 状态: 采集中"
                               FontSize="11" Foreground="#4E5969" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- 底部状态栏 -->
            <Border DockPanel.Dock="Bottom" Height="24" Background="#F5F7FA" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Padding="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="动力: 在线" FontSize="11" Foreground="#4E5969"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="冷却: 在线" FontSize="11" Foreground="#4E5969"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="台架: 在线" FontSize="11" Foreground="#4E5969"/>
                    </StackPanel>
                    <TextBlock Text="WindCore MainControl v1.0.0" FontSize="11" Foreground="#86909C" HorizontalAlignment="Right" Margin="16,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- 主体区域: 侧边栏 + 内容 -->
            <Grid ColumnDefinitions="200,*">

                <!-- 侧边栏导航 -->
                <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0" Padding="0,8,0,16">
                    <controls:SidebarNav x:Name="sidebarNav"/>
                </Border>

                <!-- 内容区域 -->
                <Border Grid.Column="1" Background="#F5F7FA" Padding="12">
                    <ContentPresenter Content="{Binding SelectedNavPage}"/>
                </Border>
            </Grid>

        </DockPanel>

        <!-- Toast 提示 -->
        <controls:Toast x:Name="toast"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,20,0,0"/>
    </Panel>
</Window>
