<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WindCore.MainControl.ViewModels"
        xmlns:views="using:WindCore.MainControl.Views"
        xmlns:controls="using:WindCore.MainControl.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1040"
        x:Class="WindCore.MainControl.Views.MainWindow"
        x:Name="mainWindow"
        Width="480" Height="420"
        WindowStartupLocation="CenterScreen"
        Title="南京609风洞测控系统 - 主控软件">

    <Panel x:DataType="vm:MainWindowViewModel">
        <!-- 登录页面 (登录成功后自动隐藏) -->
        <views:LoginView x:Name="loginView" DataContext="{Binding LoginViewModel}"/>

        <!-- 登录遮罩 (登录成功后覆盖登录页) -->
        <Panel IsVisible="{Binding IsLoggedIn}" Background="Transparent"/>

        <!-- 主页面 (登录后显示) -->
        <DockPanel IsVisible="{Binding IsLoggedIn}">

            <!-- 顶部菜单栏 -->
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="文件">
                    <MenuItem Header="退出" InputGesture="Ctrl+Q"/>
                </MenuItem>
                <MenuItem Header="帮助">
                    <MenuItem Header="关于" InputGesture="F1"/>
                </MenuItem>
            </Menu>

            <!-- 主体区域: 侧边栏 + 内容 -->
            <Grid ColumnDefinitions="200,*">

                <!-- 侧边栏导航 -->
                <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,0,1,0" Padding="0,8,0,16">
                    <controls:SidebarNav x:Name="sidebarNav"/>
                </Border>

                <!-- 内容区域 -->
                <Border Grid.Column="1" Background="#F5F7FA" Padding="12">
                    <ContentPresenter Content="{Binding SelectedNavPage}"/>
                </Border>
            </Grid>

        </DockPanel>

        <!-- Toast 提示 -->
        <controls:Toast x:Name="toast"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,20,0,0"/>
    </Panel>
</Window>
