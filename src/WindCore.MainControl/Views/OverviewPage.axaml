<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:WindCore.MainControl.Controls"
             xmlns:viewmodels="using:WindCore.MainControl.ViewModels"
             xmlns:fa="using:IconPacks.Avalonia.FontAwesome"
             x:DataType="viewmodels:OverviewPageViewModel"
             x:Class="WindCore.MainControl.Views.OverviewPage">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">

            <!-- 顶部状态栏 -->
            <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" Padding="18,12">
                <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*,Auto,*,Auto">
                    <!-- 试验状态 -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.FlaskSolid}" Width="18" Height="18" Foreground="#0052D9" VerticalAlignment="Center"/>
                        <TextBlock Text="试验:" FontSize="15" Foreground="#86909C" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ExperimentStatus}" FontSize="15" FontWeight="Bold" Foreground="#0052D9" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentExperimentName}" FontSize="14" Foreground="#4E5969" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <!-- 分隔线 -->
                    <Border Grid.Column="1" Width="1" Height="24" Background="#E8E8E8" Margin="14,0"/>
                    <!-- PLC 通讯 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="#2BA471"/>
                        <TextBlock Text="PLC:" FontSize="15" Foreground="#86909C" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PlcCommStatus}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="3" Width="1" Height="24" Background="#E8E8E8" Margin="14,0"/>
                    <!-- 数采通讯 -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="#2BA471"/>
                        <TextBlock Text="数采:" FontSize="15" Foreground="#86909C" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DaqCommStatus}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="5" Width="1" Height="24" Background="#E8E8E8" Margin="14,0"/>
                    <!-- 数据库通讯 -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" Fill="#2BA471"/>
                        <TextBlock Text="数据库:" FontSize="15" Foreground="#86909C" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DbCommStatus}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="7" Width="1" Height="24" Background="#E8E8E8" Margin="14,0"/>
                    <!-- 安全联锁 -->
                    <StackPanel Grid.Column="8" Orientation="Horizontal" Spacing="8">
                        <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.ShieldHalvedSolid}" Width="16" Height="16" Foreground="#2BA471" VerticalAlignment="Center"/>
                        <TextBlock Text="联锁:" FontSize="15" Foreground="#86909C" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding InterlockStatus}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- 试验操作按钮 -->
                    <StackPanel Grid.Column="9" Orientation="Horizontal" Spacing="8" Margin="14,0,0,0">
                        <Button Classes="success" Content="开始试验" Padding="16,8" FontSize="14" FontWeight="Bold"/>
                        <Button Classes="danger" Content="停止试验" Padding="16,8" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 仪表盘组 (UniformGrid: 宽屏均匀拉伸铺满, 窄屏自动增加行数) -->
            <UniformGrid Columns="6" RowSpacing="10" ColumnSpacing="10" MinHeight="240">
                <!-- 风速仪表盘 -->
                <Panel>
                    <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" MaxWidth="380"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.WindSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="风速" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                            </Border>
                            <controls:ModernGauge Value="{Binding WindSpeed}" Min="0" Max="120" Unit="m/s"
                                                   WarningThreshold="90" DangerThreshold="110"/>
                        </StackPanel>
                    </Border>
                </Panel>
                <!-- 电机转速仪表盘 -->
                <Panel>
                    <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" MaxWidth="380"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.GaugeSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="电机转速" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                            </Border>
                            <controls:ModernGauge Value="{Binding MotorRpm}" Min="0" Max="1800" Unit="r/min"
                                                   WarningThreshold="1500" DangerThreshold="1700"/>
                        </StackPanel>
                    </Border>
                </Panel>
                <!-- 温度仪表盘 -->
                <Panel>
                    <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" MaxWidth="380"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.TemperatureHighSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="温度" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                            </Border>
                            <controls:ModernGauge Value="{Binding MotorTemp}" Min="0" Max="60" Unit="°C"
                                                   WarningThreshold="40" DangerThreshold="55"/>
                        </StackPanel>
                    </Border>
                </Panel>
                <!-- RAT推力仪表盘 -->
                <Panel>
                    <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" MaxWidth="380"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.ArrowUpSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="RAT推力" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                            </Border>
                            <controls:ModernGauge Value="{Binding RatThrust}" Min="0" Max="5000" Unit="N"/>
                        </StackPanel>
                    </Border>
                </Panel>
                <!-- RAT转速仪表盘 -->
                <Panel>
                    <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" MaxWidth="380"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.RotateSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="RAT转速" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                            </Border>
                            <controls:ModernGauge Value="{Binding RatRpm}" Min="0" Max="10000" Unit="r/min"
                                                   WarningThreshold="8000" DangerThreshold="9000"/>
                        </StackPanel>
                    </Border>
                </Panel>
                <!-- 俯仰角仪表盘 -->
                <Panel>
                    <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8" MaxWidth="380"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <StackPanel>
                            <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.PlaneSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="俯仰角" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                            </Border>
                            <controls:ModernGauge Value="{Binding Pitch}" Min="-20" Max="20" Unit="°"/>
                        </StackPanel>
                    </Border>
                </Panel>
            </UniformGrid>

            <!-- 辅助指标卡片 (UniformGrid: 宽屏均匀拉伸铺满) -->
            <UniformGrid Columns="5" ColumnSpacing="10">
                <Border Background="#FFFFFF" BorderBrush="#D6E4FF" BorderThickness="1" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="10" Height="10" Fill="#0052D9"/>
                            <TextBlock Text="电机频率" FontSize="14" Foreground="#86909C"/>
                        </StackPanel>
                        <TextBlock Text="{Binding MotorFrequency, StringFormat={}{0:F1} Hz}" FontSize="24" FontWeight="Bold" Foreground="#0052D9" FontFamily="Consolas" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFFFF" BorderBrush="#B7E4C7" BorderThickness="1" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="10" Height="10" Fill="#2BA471"/>
                            <TextBlock Text="冷却液流量" FontSize="14" Foreground="#86909C"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CoolingFlow, StringFormat={}{0:F1} L/min}" FontSize="24" FontWeight="Bold" Foreground="#2BA471" FontFamily="Consolas" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFFFF" BorderBrush="#D6E4FF" BorderThickness="1" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="10" Height="10" Fill="#0052D9"/>
                            <TextBlock Text="RAT扭矩" FontSize="14" Foreground="#86909C"/>
                        </StackPanel>
                        <TextBlock Text="{Binding RatTorque, StringFormat={}{0:F1} N·m}" FontSize="24" FontWeight="Bold" Foreground="#0052D9" FontFamily="Consolas" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFFFF" BorderBrush="#FFD5B8" BorderThickness="1" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="10" Height="10" Fill="#ED7B2F"/>
                            <TextBlock Text="RAT功率" FontSize="14" Foreground="#86909C"/>
                        </StackPanel>
                        <TextBlock Text="{Binding RatPower, StringFormat={}{0:F1} kW}" FontSize="24" FontWeight="Bold" Foreground="#ED7B2F" FontFamily="Consolas" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFFFF" BorderBrush="#D6E4FF" BorderThickness="1" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="10" Height="10" Fill="#0052D9"/>
                            <TextBlock Text="侧滑角" FontSize="14" Foreground="#86909C"/>
                        </StackPanel>
                        <TextBlock Text="{Binding YawActual, StringFormat={}{0:F1}°}" FontSize="24" FontWeight="Bold" Foreground="#0052D9" FontFamily="Consolas" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 分系统状态面板 (UniformGrid: 5 列 — 动力/冷却/台架/龙门架/RAT) -->
            <UniformGrid Columns="5" ColumnSpacing="10">
                <!-- 动力系统 -->
                <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.BoltSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="动力系统" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{Binding MotorCommStatus, Converter={x:Static controls:CommStatusColorConverter.Instance}}"/>
                                    <TextBlock Text="{Binding MotorCommStatus}" FontSize="12" Foreground="#86909C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Margin="14,12" Spacing="10">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="电机状态" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding MotorStatus}" Grid.Column="1" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="#2BA471"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="绕组温度" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding MotorWindingTemp, StringFormat={}{0:F0} °C}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#ED7B2F"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="电机电流" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding MotorCurrent, StringFormat={}{0:F1} A}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#1D2129"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="变频器状态" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding InverterStatus}" Grid.Column="1" HorizontalAlignment="Right" FontSize="16" Foreground="#2BA471"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 操作区 -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="目标" FontSize="14" Foreground="#86909C" VerticalAlignment="Center" Width="40"/>
                                <TextBox Text="{Binding PowerDrive.TargetWindSpeed}" Width="72" FontSize="14" Padding="6,4" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="m/s" FontSize="13" Foreground="#4E5969" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="success" Content="启动" Click="OnStartMotorClick" Padding="16,7" FontSize="14" FontWeight="Bold"/>
                                <Button Classes="danger" Content="停止" Click="OnStopMotorClick" Padding="16,7" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- 冷却系统 -->
                <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.SnowflakeSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="冷却系统" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{Binding CoolingCommStatus, Converter={x:Static controls:CommStatusColorConverter.Instance}}"/>
                                    <TextBlock Text="{Binding CoolingCommStatus}" FontSize="12" Foreground="#86909C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Margin="14,12" Spacing="10">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="出水温度" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding CoolingOutTemp, StringFormat={}{0:F1} °C}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#1D2129"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="回水温度" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding CoolingReturnTemp, StringFormat={}{0:F1} °C}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#1D2129"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="管路压力" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding CoolingPressure, StringFormat={}{0:F1} MPa}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#ED7B2F"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="水泵状态" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding PumpStatus}" Grid.Column="1" HorizontalAlignment="Right" FontSize="16" Foreground="#2BA471"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 操作区 -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="目标" FontSize="14" Foreground="#86909C" VerticalAlignment="Center" Width="40"/>
                                <TextBox Text="{Binding Cooling.TargetTemp}" Width="72" FontSize="14" Padding="6,4" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="°C" FontSize="13" Foreground="#4E5969" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="success" Content="启动" Click="OnStartPumpClick" Padding="16,7" FontSize="14" FontWeight="Bold"/>
                                <Button Classes="danger" Content="停止" Click="OnStopPumpClick" Padding="16,7" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- 台架系统 -->
                <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.GearsSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="台架系统" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{Binding StandCommStatus, Converter={x:Static controls:CommStatusColorConverter.Instance}}"/>
                                    <TextBlock Text="{Binding StandCommStatus}" FontSize="12" Foreground="#86909C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Margin="14,12" Spacing="10">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="俯仰角 目标/实际" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding PitchSetpoint, StringFormat={}{0:F1}°} / {Binding PitchActual, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#1D2129"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="侧滑角 目标/实际" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding YawSetpoint, StringFormat={}{0:F1}°} / {Binding YawActualVal, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#1D2129"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="俯仰偏差" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding PitchDeviation, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#2BA471"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="侧滑偏差" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding YawDeviation, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#2BA471"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 操作区 -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="俯仰" FontSize="13" Foreground="#86909C" VerticalAlignment="Center" Width="40"/>
                                <TextBox Text="{Binding GantryCtrl.PitchSetpoint}" Width="68" FontSize="13" Padding="6,4" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="°" FontSize="13" Foreground="#4E5969" VerticalAlignment="Center"/>
                                <Button Content="设定" Command="{Binding SetPitchAngleCommand}" Padding="12,6" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="侧滑" FontSize="13" Foreground="#86909C" VerticalAlignment="Center" Width="40"/>
                                <TextBox Text="{Binding GantryCtrl.YawSetpoint}" Width="68" FontSize="13" Padding="6,4" TextAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="°" FontSize="13" Foreground="#4E5969" VerticalAlignment="Center"/>
                                <Button Content="设定" Command="{Binding SetYawAngleCommand}" Padding="12,6" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="俯仰回零" Click="OnPitchHomeClick" Padding="16,7" FontSize="13"/>
                                <Button Content="侧滑回零" Click="OnYawHomeClick" Padding="16,7" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- RAT负载系统 -->
                <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.WeightHangingSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="RAT负载系统" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{Binding RatCommStatus, Converter={x:Static controls:CommStatusColorConverter.Instance}}"/>
                                    <TextBlock Text="{Binding RatCommStatus}" FontSize="12" Foreground="#86909C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Margin="14,12" Spacing="10">
                            <!-- 模式切换 -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="载荷模式" FontSize="13" Foreground="#86909C" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <ComboBox ItemsSource="{Binding Rat.ModeOptions}" SelectedItem="{Binding Rat.RatMode}" FontSize="14" Padding="6,4"/>
                                    <Button Grid.Column="1" Content="应用" Command="{Binding ApplyRatModeCommand}" Padding="14,6" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 状态显示 -->
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="推力" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding RatThrust, StringFormat={}{0:F0} N}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#0052D9"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="转速" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding RatRpm, StringFormat={}{0:F0} r/min}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#2BA471"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="扭矩" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding RatTorque, StringFormat={}{0:F1} N·m}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#ED7B2F"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="传感器" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding SensorStatus}" Grid.Column="1" HorizontalAlignment="Right" FontSize="16" Foreground="#2BA471"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 目标参数控制 -->
                            <TextBlock Text="目标参数" FontSize="13" Foreground="#86909C" FontWeight="SemiBold"/>
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="推力 (N)" FontSize="12" Foreground="#4E5969"/>
                                        <TextBox Text="{Binding Rat.TargetThrust}" FontSize="14" Padding="6,4" TextAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="设定" Command="{Binding ApplyRatTargetThrustCommand}" Padding="14,6" FontSize="13" Margin="8,20,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="转速 (r/min)" FontSize="12" Foreground="#4E5969"/>
                                        <TextBox Text="{Binding Rat.TargetRpm}" FontSize="14" Padding="6,4" TextAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="设定" Command="{Binding ApplyRatTargetRpmCommand}" Padding="14,6" FontSize="13" Margin="8,20,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="扭矩 (N·m)" FontSize="12" Foreground="#4E5969"/>
                                        <TextBox Text="{Binding Rat.TargetTorque}" FontSize="14" Padding="6,4" TextAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="设定" Command="{Binding ApplyRatTargetTorqueCommand}" Padding="14,6" FontSize="13" Margin="8,20,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- 龙门架 -->
                <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.LocationCrosshairsSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="龙门架" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{Binding GantryCommStatus, Converter={x:Static controls:CommStatusColorConverter.Instance}}"/>
                                    <TextBlock Text="{Binding GantryCommStatus}" FontSize="12" Foreground="#86909C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Margin="14,12" Spacing="10">
                            <!-- 实际位置 -->
                            <TextBlock Text="实际位置" FontSize="13" Foreground="#86909C" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="X:" FontSize="13" Foreground="#86909C"/>
                                <TextBlock Text="{Binding GantryX, StringFormat={}{0:F1} mm}" Grid.Column="1" HorizontalAlignment="Center" FontSize="18" FontFamily="Consolas" Foreground="#0052D9"/>
                                <TextBlock Text="Vx:" Grid.Column="2" FontSize="12" Foreground="#86909C" Margin="8,0,0,0"/>
                                <TextBlock Text="{Binding GantrySpeedX, StringFormat={}{0:F1} mm/s}" Grid.Column="2" HorizontalAlignment="Right" FontSize="14" FontFamily="Consolas" Foreground="#4E5969" Margin="24,0,0,0"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="Y:" FontSize="13" Foreground="#86909C"/>
                                <TextBlock Text="{Binding GantryY, StringFormat={}{0:F1} mm}" Grid.Column="1" HorizontalAlignment="Center" FontSize="18" FontFamily="Consolas" Foreground="#2BA471"/>
                                <TextBlock Text="Vy:" Grid.Column="2" FontSize="12" Foreground="#86909C" Margin="8,0,0,0"/>
                                <TextBlock Text="{Binding GantrySpeedY, StringFormat={}{0:F1} mm/s}" Grid.Column="2" HorizontalAlignment="Right" FontSize="14" FontFamily="Consolas" Foreground="#4E5969" Margin="24,0,0,0"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="Z:" FontSize="13" Foreground="#86909C"/>
                                <TextBlock Text="{Binding GantryZ, StringFormat={}{0:F1} mm}" Grid.Column="1" HorizontalAlignment="Center" FontSize="18" FontFamily="Consolas" Foreground="#ED7B2F"/>
                                <TextBlock Text="Vz:" Grid.Column="2" FontSize="12" Foreground="#86909C" Margin="8,0,0,0"/>
                                <TextBlock Text="{Binding GantrySpeedZ, StringFormat={}{0:F1} mm/s}" Grid.Column="2" HorizontalAlignment="Right" FontSize="14" FontFamily="Consolas" Foreground="#4E5969" Margin="24,0,0,0"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 目标位置控制 -->
                            <TextBlock Text="目标位置 (mm)" FontSize="13" Foreground="#86909C" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                <StackPanel>
                                    <TextBlock Text="X" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Gantry.TargetX}" FontSize="13" Padding="4,4" TextAlignment="Center" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Y" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Gantry.TargetY}" FontSize="13" Padding="4,4" TextAlignment="Center" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Z" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Gantry.TargetZ}" FontSize="13" Padding="4,4" TextAlignment="Center" FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>
                            <!-- 速度设置 -->
                            <TextBlock Text="移动速度 (mm/s)" FontSize="13" Foreground="#86909C" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                <StackPanel>
                                    <TextBlock Text="Vx" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Gantry.SpeedX}" FontSize="13" Padding="4,4" TextAlignment="Center" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Vy" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Gantry.SpeedY}" FontSize="13" Padding="4,4" TextAlignment="Center" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Vz" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding Gantry.SpeedZ}" FontSize="13" Padding="4,4" TextAlignment="Center" FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>
                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="primary" Content="移动" Command="{Binding GantryMoveToPositionCommand}" Padding="18,7" FontSize="13" FontWeight="Bold"/>
                                <Button Content="回零" Command="{Binding GantryMoveHomeCommand}" Padding="18,7" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- 桨距角测量 -->
                <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="14,10" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.FanSolid}" Width="16" Height="16" Foreground="#0052D9" VerticalAlignment="Center"/>
                                    <TextBlock Text="桨距角" FontSize="15" FontWeight="Bold" Foreground="#0052D9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{Binding BladePitchCommStatus, Converter={x:Static controls:CommStatusColorConverter.Instance}}"/>
                                    <TextBlock Text="{Binding BladePitchCommStatus}" FontSize="12" Foreground="#86909C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Margin="14,12" Spacing="10">
                            <!-- 实际角度 -->
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="桨叶 1" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding BladePitch1, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#0052D9"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="桨叶 2" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding BladePitch2, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#2BA471"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="桨叶 3" FontSize="14" Foreground="#86909C"/>
                                <TextBlock Text="{Binding BladePitch3, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontFamily="Consolas" Foreground="#ED7B2F"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="平均值" FontSize="14" FontWeight="SemiBold" Foreground="#1D2129"/>
                                <TextBlock Text="{Binding BladePitchAvg, StringFormat={}{0:F1}°}" Grid.Column="1" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" FontFamily="Consolas" Foreground="#0052D9"/>
                            </Grid>
                            <Separator Margin="0,4" Opacity="0.3"/>
                            <!-- 目标角度控制 -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="目标角度 (°)" FontSize="13" Foreground="#86909C" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <StackPanel>
                                        <TextBlock Text="桨叶 1" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                        <TextBox Text="{Binding BladePitch.TargetPitch1}" FontSize="14" Padding="6,4" TextAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="桨叶 2" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                        <TextBox Text="{Binding BladePitch.TargetPitch2}" FontSize="14" Padding="6,4" TextAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="桨叶 3" FontSize="12" Foreground="#4E5969" HorizontalAlignment="Center"/>
                                        <TextBox Text="{Binding BladePitch.TargetPitch3}" FontSize="14" Padding="6,4" TextAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                </Grid>
                                <Button Content="设定" Command="{Binding SetBladePitchCommand}" Padding="14,6" FontSize="13" FontWeight="Bold" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 风速趋势 + 报警信息 -->
            <Grid ColumnDefinitions="1.2*,*" ColumnSpacing="10">
                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#F0F5FF" Padding="16,12" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.ChartLineSolid}" Width="18" Height="18" Foreground="#0052D9" VerticalAlignment="Center"/>
                                <TextBlock Text="风速趋势" FontSize="16" FontWeight="SemiBold" Foreground="#0052D9" VerticalAlignment="Center"/>
                                <Border Background="#0052D9" CornerRadius="12" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock Text="实时" FontSize="11" Foreground="#FFFFFF"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Height="220" Background="#FAFBFC" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="6" Margin="14,14,14,14">
                            <TextBlock Text="风速实时曲线图 (ScottPlot / LiveCharts2)"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#86909C" FontSize="15"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <Border Background="#FFF6F7" Padding="16,12" BorderBrush="#FFE0E3" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.BellSolid}" Width="18" Height="18" Foreground="#E34D59" VerticalAlignment="Center"/>
                                <TextBlock Text="报警信息" FontSize="16" FontWeight="SemiBold" Foreground="#E34D59" VerticalAlignment="Center"/>
                                <Border Background="#E34D59" CornerRadius="12" Padding="10,3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Alarms.Count}" FontSize="12" Foreground="#FFFFFF" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{Binding Alarms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:AlarmRecordViewModel">
                                    <Border Padding="14,12" BorderBrush="#F5F7FA" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <Border Grid.Column="0" CornerRadius="6" Padding="8,3" MinWidth="48" VerticalAlignment="Center"
                                                    Background="{Binding Level, Converter={x:Static controls:AlarmLevelColorConverter.Instance}}">
                                                <TextBlock Text="{Binding Level, StringFormat={}{0}级}" FontSize="12" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Time}" Grid.Column="1" FontSize="13" Foreground="#86909C" FontFamily="Consolas" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Description}" Grid.Column="2" FontSize="14" Foreground="#1D2129" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <Border Grid.Column="3" CornerRadius="6" Padding="8,3" VerticalAlignment="Center"
                                                    Background="{Binding Status, Converter={x:Static controls:AlarmStatusBgConverter.Instance}}">
                                                <TextBlock Text="{Binding Status}" FontSize="12"
                                                           Foreground="{Binding Status, Converter={x:Static controls:AlarmStatusTextColorConverter.Instance}}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 关键参数波形图 -->
            <Border Background="#FFFFFF" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border Background="#F0F5FF" Padding="16,12" BorderBrush="#D6E4FF" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <fa:PackIconFontAwesome Kind="{x:Static fa:PackIconFontAwesomeKind.WaveSquareSolid}" Width="18" Height="18" Foreground="#0052D9" VerticalAlignment="Center"/>
                            <TextBlock Text="关键参数波形" FontSize="16" FontWeight="SemiBold" Foreground="#0052D9" VerticalAlignment="Center"/>
                            <Border Background="#0052D9" CornerRadius="12" Padding="10,3" VerticalAlignment="Center">
                                <TextBlock Text="实时" FontSize="11" Foreground="#FFFFFF"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Height="200" Background="#FAFBFC" BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="6" Margin="14,14,14,14">
                        <TextBlock Text="多参数实时波形 (ScottPlot) — 风速 / 温度 / 推力 / 转速 实时曲线"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#86909C" FontSize="15"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="14,6,14,10" Spacing="28">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="24" Height="4" Fill="#0052D9" VerticalAlignment="Center"/>
                            <TextBlock Text="风速 (m/s)" FontSize="13" Foreground="#4E5969"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="24" Height="4" Fill="#ED7B2F" VerticalAlignment="Center"/>
                            <TextBlock Text="温度 (°C)" FontSize="13" Foreground="#4E5969"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="24" Height="4" Fill="#2BA471" VerticalAlignment="Center"/>
                            <TextBlock Text="推力 (N)" FontSize="13" Foreground="#4E5969"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Rectangle Width="24" Height="4" Fill="#885ED3" VerticalAlignment="Center"/>
                            <TextBlock Text="转速 (r/min)" FontSize="13" Foreground="#4E5969"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
        <controls:ConfirmDialog x:Name="confirmDialog"/>
    </Grid>
</UserControl>
